---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="LeShea Academy" description="Education, training, classes, and professional learning experiences." />
	</head>
	<body>
		<Header />
		<main>
			<h1>LeShea Academy</h1>

			<p>
				LeShea Academy is the educational division of LeShea Group dedicated to learning, professional growth, leadership development, and transformational teaching experiences.
			</p>

			<h2>Educational Offerings</h2>
			<ul>
				<li>Professional development courses</li>
				<li>Healthcare and nursing education</li>
				<li>CPR and life support training</li>
				<li>Leadership and communication workshops</li>
				<li>Digital learning resources</li>
				<li>Community education initiatives</li>
			</ul>

			<h2>Future Member Features</h2>
			<ul>
				<li>Student login portal</li>
				<li>Online classes and learning modules</li>
				<li>Downloadable educational resources</li>
				<li>Certificates and course completion tracking</li>
				<li>Exclusive member content</li>
			</ul>

			<p>
				Expanded course offerings and member access features are coming soon.
			</p>
		</main>
		<Footer />
	</body>
</html>
