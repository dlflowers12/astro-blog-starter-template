---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Shop | LeShea Group" description="Digital resources, guides, workbooks, educational products, and signature offerings." />
	</head>
	<body>
		<Header />
		<main>
			<h1>Shop</h1>

			<p>
				The LeShea Group Shop will feature curated educational resources, digital products, signature tools, and transformational materials designed to support growth, learning, and leadership.
			</p>

			<h2>Future Shop Categories</h2>
			<ul>
				<li>Digital guides and workbooks</li>
				<li>Educational resources and templates</li>
				<li>Leadership and empowerment tools</li>
				<li>Workshop materials</li>
				<li>Branded merchandise and signature products</li>
				<li>Professional development resources</li>
			</ul>

			<h2>Coming Soon</h2>
			<p>
				The online shop and featured products are currently in development.
			</p>
		</main>
		<Footer />
	</body>
</html>
