---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main>
			<section class="hero">
				<img src="/leshea-logo.png" alt="LeShea Group LLC Logo" class="logo" />

				<p class="eyebrow">A refined brand house for education, leadership, media, and impact</p>

				<h1>Where purpose becomes platform.</h1>

				<p class="hero-text">
					LeShea Group curates professional learning, signature experiences, media,
					speaking, community initiatives, and service-based offerings with excellence,
					clarity, and purpose.
				</p>

				<div class="buttons">
					<a href="/services">Explore Services</a>
					<a href="/contact" class="secondary">Start an Inquiry</a>
				</div>
			</section>

			<section class="statement">
				<p>
					Designed for individuals, organizations, learners, and communities seeking meaningful growth through education, service, storytelling, and transformational experiences.
				</p>
			</section>

			<section class="pillars">
				<a href="/services" class="pillar">
					<span>01</span>
					<h2>Professional Services</h2>
					<p>CPR classes, workshops, speaking deposits, notary services, consultations, and digital products.</p>
				</a>

				<a href="/signature" class="pillar">
					<span>02</span>
					<h2>LeShea Signature</h2>
					<p>A premium personal and executive brand space for leadership, presence, teaching, and signature experiences.</p>
				</a>

				<a href="/academy" class="pillar">
					<span>03</span>
					<h2>Education & Training</h2>
					<p>Professional learning, healthcare education, CPR training, leadership development, and future academy access.</p>
				</a>

				<a href="/media" class="pillar">
					<span>04</span>
					<h2>Media & Impact</h2>
					<p>Storytelling, podcasting, community engagement, and meaningful content designed to educate and inspire.</p>
				</a>
			</section>

			<section class="featured">
				<div>
					<p class="eyebrow">Now accepting inquiries</p>
					<h2>Classes, speaking, workshops, notary services, and custom payments are available.</h2>
				</div>
				<a href="/services">View Services & Payments</a>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	body {
		background: #fbfaf7;
	}

	main {
		max-width: 1180px;
		margin: 0 auto;
		padding: 3rem 1.25rem 5rem;
	}

	.hero {
		text-align: center;
		padding: 4.5rem 1rem 3.5rem;
		border-bottom: 1px solid #e9e2d4;
	}

	.logo {
		max-width: 280px;
		width: 76%;
		margin-bottom: 2.25rem;
	}

	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.18em;
		font-size: 0.74rem;
		color: #9a762f;
		font-weight: 700;
	}

	h1 {
		font-size: clamp(3rem, 7vw, 6.2rem);
		line-height: 0.95;
		letter-spacing: -0.06em;
		margin: 1rem auto;
		max-width: 980px;
		color: #111;
		font-weight: 700;
	}

	.hero-text {
		max-width: 760px;
		margin: 1.5rem auto;
		font-size: 1.12rem;
		line-height: 1.85;
		color: #393939;
	}

	.buttons {
		display: flex;
		justify-content: center;
		gap: 0.85rem;
		flex-wrap: wrap;
		margin-top: 2rem;
	}

	.buttons a,
	.featured a {
		background: #111;
		color: white;
		text-decoration: none;
		padding: 0.85rem 1.25rem;
		border-radius: 999px;
		font-weight: 600;
		font-size: 0.95rem;
	}

	.buttons .secondary {
		background: transparent;
		color: #111;
		border: 1px solid #cfc7b8;
	}

	.statement {
		max-width: 900px;
		margin: 4rem auto;
		text-align: center;
	}

	.statement p {
		font-size: clamp(1.5rem, 3vw, 2.4rem);
		line-height: 1.25;
		letter-spacing: -0.035em;
		color: #161616;
	}

	.pillars {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1px;
		background: #e4dccd;
		border: 1px solid #e4dccd;
		margin: 4rem 0;
	}

	.pillar {
		background: #fbfaf7;
		padding: 2rem;
		text-decoration: none;
		color: #111;
		min-height: 260px;
	}

	.pillar span {
		color: #9a762f;
		font-size: 0.82rem;
		font-weight: 700;
	}

	.pillar h2 {
		font-size: 1.35rem;
		line-height: 1.15;
		margin: 1rem 0;
		letter-spacing: -0.03em;
	}

	.pillar p {
		color: #484848;
		line-height: 1.7;
	}

	.featured {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		background: #111;
		color: white;
		border-radius: 1.35rem;
		padding: 2.5rem;
	}

	.featured h2 {
		font-size: clamp(1.6rem, 3vw, 2.7rem);
		line-height: 1.08;
		letter-spacing: -0.045em;
		margin: 0.75rem 0 0;
		max-width: 800px;
	}

	.featured a {
		background: #fff;
		color: #111;
		white-space: nowrap;
	}

	@media (max-width: 900px) {
		.pillars {
			grid-template-columns: 1fr 1fr;
		}

		.featured {
			flex-direction: column;
			align-items: flex-start;
		}
	}

	@media (max-width: 620px) {
		main {
			padding: 2rem 1rem 4rem;
		}

		.hero {
			padding-top: 3rem;
		}

		.pillars {
			grid-template-columns: 1fr;
		}

		.pillar {
			min-height: auto;
		}
	}
</style>
