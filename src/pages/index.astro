---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section>
				<h1>LeShea Group</h1>
				<p>
					A purpose-driven brand house created to educate, equip, inspire, and build meaningful platforms for growth.
				</p>
				<p>
					LeShea Group serves as the parent home for education, media, workshops, community impact, digital resources, and future creative ventures.
				</p>
			</section>

			<section>
				<h2>Our Brand Family</h2>
				<ul>
					<li><strong>LeShea Academy:</strong> Classes, learning resources, professional development, and educational tools.</li>
					<li><strong>LeShea Media:</strong> Podcasting, storytelling, digital media, and creative content.</li>
					<li><strong>LeShea Foundation:</strong> Community-centered impact, service, outreach, and empowerment.</li>
					<li><strong>LeShea Workshops:</strong> Transformational workshops, speaking experiences, and guided learning events.</li>
				</ul>
			</section>

			<section>
				<h2>What We Offer</h2>
				<ul>
					<li>Educational classes and learning resources</li>
					<li>Workshops and speaking experiences</li>
					<li>Digital products, guides, and workbooks</li>
					<li>Podcast and media content</li>
					<li>Community engagement and empowerment initiatives</li>
				</ul>
			</section>

			<section>
				<h2>Our Mission</h2>
				<p>
					To create spaces, resources, and experiences that help people grow with clarity, confidence, purpose, and excellence.
				</p>
			</section>

			<section>
				<h2>Coming Soon</h2>
				<p>
					LeShea Group is growing. Soon, you will be able to explore classes, purchase resources, connect with workshops, and access brand-specific platforms through our family of sites.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
