---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main>
			<section class="hero">
				<img src="/leshea-logo.png" alt="LeShea Group LLC Logo" class="logo" />

				<p class="eyebrow">Education • Media • Leadership • Community Impact</p>

				<h1>Building refined spaces for growth, learning, and purpose.</h1>

				<p class="hero-text">
					LeShea Group is a purpose-driven brand house offering education, signature experiences,
					classes, media, speaking, notary services, digital resources, and community-centered impact.
				</p>

				<div class="buttons">
					<a href="/services">Explore Services</a>
					<a href="/contact">Start an Inquiry</a>
				</div>
			</section>

			<section class="grid">
				<a href="/signature" class="card">
					<h2>LeShea Signature</h2>
					<p>Executive presence, transformational teaching, signature experiences, and purpose-driven leadership.</p>
				</a>

				<a href="/services" class="card">
					<h2>Classes & Services</h2>
					<p>CPR classes, workshops, speaking deposits, notary services, consultations, and digital products.</p>
				</a>

				<a href="/academy" class="card">
					<h2>LeShea Academy</h2>
					<p>Professional education, learning resources, training experiences, and future member access.</p>
				</a>

				<a href="/media" class="card">
					<h2>LeShea Media</h2>
					<p>Storytelling, podcasting, meaningful conversations, and digital content that educates and inspires.</p>
				</a>
			</section>

			<section class="feature">
				<h2>Services & Experiences</h2>
				<div class="service-list">
					<p>CPR & health education classes</p>
					<p>Speaking engagements</p>
					<p>Workshops and trainings</p>
					<p>Digital products and resources</p>
					<p>Notary Public services</p>
					<p>Community partnerships</p>
				</div>
			</section>

			<section class="closing">
				<h2>Purposeful. Professional. Built with excellence.</h2>
				<p>
					LeShea Group is growing into a refined platform for education, media, resources,
					classes, speaking, service, and community impact.
				</p>
				<a href="/services">View Services</a>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1180px;
		margin: 0 auto;
		padding: 3rem 1.25rem;
	}

	.hero {
		text-align: center;
		padding: 4rem 1rem 4.5rem;
	}

	.logo {
		max-width: 300px;
		width: 78%;
		margin-bottom: 2rem;
	}

	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.17em;
		font-size: 0.76rem;
		color: #9a762f;
		font-weight: 700;
	}

	h1 {
		font-size: clamp(2.2rem, 5.2vw, 4.45rem);
		line-height: 1.05;
		letter-spacing: -0.045em;
		margin: 1rem auto;
		max-width: 920px;
		color: #111;
		font-weight: 700;
	}

	.hero-text {
		max-width: 760px;
		margin: 1.35rem auto;
		font-size: 1.08rem;
		line-height: 1.8;
		color: #3d3d3d;
	}

	.buttons {
		display: flex;
		gap: 0.85rem;
		justify-content: center;
		flex-wrap: wrap;
		margin-top: 2rem;
	}

	.buttons a,
	.closing a {
		background: #222;
		color: white;
		padding: 0.82rem 1.2rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
	}

	.buttons a:nth-child(2) {
		background: white;
		color: #111;
		border: 1px solid #ddd;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1rem;
		margin: 2rem 0 3.5rem;
	}

	.card {
		padding: 1.45rem;
		border: 1px solid #eeeeee;
		border-radius: 1.15rem;
		text-decoration: none;
		color: #111;
		background: #fff;
		box-shadow: 0 12px 32px rgba(0, 0, 0, 0.045);
	}

	.card h2 {
		font-size: 1.18rem;
		margin-bottom: 0.7rem;
	}

	.card p {
		color: #444;
		line-height: 1.65;
	}

	.feature {
		background: #f8f8f8;
		color: #111;
		border-radius: 1.5rem;
		padding: 3rem;
		margin: 3rem 0;
		border: 1px solid #ececec;
	}

	.feature h2 {
		font-size: 1.9rem;
		margin-bottom: 1.5rem;
		color: #111;
	}

	.service-list {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.service-list p {
		background: white;
		border: 1px solid #e9e9e9;
		padding: 1rem;
		border-radius: 1rem;
		margin: 0;
		color: #333;
		box-shadow: 0 6px 18px rgba(0, 0, 0, 0.04);
	}

	.closing {
		text-align: center;
		padding: 4rem 1rem;
	}

	.closing h2 {
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1.1;
		margin-bottom: 1rem;
		color: #111;
	}

	.closing p {
		max-width: 700px;
		margin: 0 auto 2rem;
		line-height: 1.8;
		color: #444;
	}

	@media (max-width: 900px) {
		.grid,
		.service-list {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 620px) {
		main {
			padding: 2rem 1rem;
		}

		.grid,
		.service-list {
			grid-template-columns: 1fr;
		}

		.feature {
			padding: 2rem;
		}
	}
</style>
