---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Contact | LeShea Group" description="Contact LeShea Group for classes, speaking engagements, workshops, partnerships, and inquiries." />
	</head>
	<body>
		<Header />
		<main>
			<h1>Contact LeShea Group</h1>

			<p>
				Thank you for your interest in LeShea Group. We welcome inquiries regarding classes, workshops, speaking engagements, collaborations, partnerships, and future opportunities.
			</p>

			<h2>Inquiry Areas</h2>
			<ul>
				<li>Speaking engagements</li>
				<li>Workshop bookings</li>
				<li>CPR and educational classes</li>
				<li>Professional collaborations</li>
				<li>Community partnerships</li>
				<li>Notary Public services</li>
			</ul>

			<h2>Contact Information</h2>
			<p>
				Official contact methods and inquiry forms are currently being finalized and will be added soon.
			</p>

			<p>
				Please check back soon for additional contact and booking options.
			</p>
		</main>
		<Footer />
	</body>
</html>
