---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Speaking Engagements | LeShea Group" description="Speaking engagements, workshops, leadership sessions, and transformational experiences." />
	</head>
	<body>
		<Header />
		<main>
			<h1>Speaking Engagements</h1>

			<p>
				LeShea Group offers impactful speaking experiences centered around leadership, education, empowerment, professional growth, healthcare, purpose, and transformation.
			</p>

			<h2>Speaking Topics</h2>
			<ul>
				<li>Leadership and professional growth</li>
				<li>Healthcare education and nursing excellence</li>
				<li>Women in leadership and purpose-driven success</li>
				<li>Personal development and empowerment</li>
				<li>Community engagement and impact</li>
				<li>Educational workshops and training sessions</li>
			</ul>

			<h2>Available Services</h2>
			<ul>
				<li>Conference speaking engagements</li>
				<li>Workshops and breakout sessions</li>
				<li>Panel discussions</li>
				<li>Educational seminars</li>
				<li>CPR and community education sessions</li>
				<li>Notary Public services</li>
			</ul>

			<h2>Booking Information</h2>
			<p>
				Booking requests and event inquiries are currently being accepted. Additional scheduling and inquiry features are coming soon.
			</p>
		</main>
		<Footer />
	</body>
</html>
