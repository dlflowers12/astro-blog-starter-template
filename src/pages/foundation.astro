---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="LeShea Foundation" description="Community impact, outreach, empowerment, and service initiatives." />
	</head>
	<body>
		<Header />
		<main>
			<h1>LeShea Foundation</h1>

			<p>
				LeShea Foundation exists to support meaningful community impact through education, empowerment, outreach, and service-centered initiatives.
			</p>

			<h2>Focus Areas</h2>
			<ul>
				<li>Community engagement initiatives</li>
				<li>Educational outreach and support</li>
				<li>Women and youth empowerment</li>
				<li>Health education and awareness</li>
				<li>Leadership development opportunities</li>
				<li>Collaborative partnerships and service projects</li>
			</ul>

			<h2>Vision</h2>
			<p>
				To build stronger communities by creating opportunities for growth, learning, leadership, and empowerment.
			</p>

			<p>
				Community programs and outreach initiatives are currently in development.
			</p>
		</main>
		<Footer />
	</body>
</html>
