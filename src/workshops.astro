---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Workshops | LeShea Group" description="Transformational workshops, trainings, and leadership experiences." />
	</head>
	<body>
		<Header />
		<main>
			<h1>Workshops</h1>

			<p>
				LeShea Group workshops are designed to create engaging, transformational, and practical learning experiences that inspire growth and meaningful action.
			</p>

			<h2>Workshop Experiences</h2>
			<ul>
				<li>Leadership and empowerment workshops</li>
				<li>Healthcare and professional development training</li>
				<li>Community-centered educational sessions</li>
				<li>Women’s growth and leadership experiences</li>
				<li>Interactive teaching and collaborative learning events</li>
				<li>Purpose-driven transformational sessions</li>
			</ul>

			<h2>Available Formats</h2>
			<ul>
				<li>Virtual workshops</li>
				<li>In-person workshops</li>
				<li>Conference breakout sessions</li>
				<li>Small group intensives</li>
				<li>Corporate and organizational training</li>
			</ul>

			<p>
				Upcoming workshops and registration opportunities will be announced soon.
			</p>
		</main>
		<Footer />
	</body>
</html>
