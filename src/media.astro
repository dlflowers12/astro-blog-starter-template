---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="LeShea Media" description="Podcasting, storytelling, digital media, and creative content." />
	</head>
	<body>
		<Header />
		<main>
			<h1>LeShea Media</h1>

			<p>
				LeShea Media is the storytelling and digital media division of LeShea Group, created to amplify voices, conversations, and content that educate, inspire, and connect.
			</p>

			<h2>Media Focus</h2>
			<ul>
				<li>Podcast production and storytelling</li>
				<li>Digital content and brand media</li>
				<li>Educational and inspirational conversations</li>
				<li>Community-centered stories</li>
				<li>Creative campaigns and media projects</li>
			</ul>

			<h2>Coming Soon</h2>
			<p>
				Podcast episodes, featured conversations, and media projects will be added soon.
			</p>
		</main>
		<Footer />
	</body>
</html>
