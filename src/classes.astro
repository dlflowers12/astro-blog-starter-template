---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Classes | LeShea Group" description="CPR, health education, professional development, and community learning experiences." />
	</head>
	<body>
		<Header />
		<main>
			<h1>Classes</h1>
			<p>
				LeShea Group offers practical, professional, and community-centered learning experiences designed to educate, equip, and empower.
			</p>

			<h2>Current & Future Class Offerings</h2>
			<ul>
				<li>CPR and Basic Life Support education</li>
				<li>Health and wellness education</li>
				<li>Professional development workshops</li>
				<li>Leadership and communication trainings</li>
				<li>Community education sessions</li>
			</ul>

			<h2>Booking & Registration</h2>
			<p>
				Class registration and scheduling details are coming soon. For class inquiries, please contact LeShea Group directly.
			</p>
		</main>
		<Footer />
	</body>
</html>
